---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Ava from '@src/assets/img/xcflight.jpg';
import Prose from '../components/Prose.astro';
---

<BaseLayout title='About Me' description='Lorem ipsum dolor sit amet'>
	<div class='container'>
		<main class='prose text-lg dark:prose-invert'>
			<article>
				<div class='w-full md:flex md:items-center gap-16 mb-10'>
					<div class='text-pretty leading-9'>
						<h1 class='text-4xl font-bold mb-4'>『ov172xcr』って何のこと?</h1>
						<Prose>
							<div class='text-lg'>
								<p>
									今では更新されてしまいましたが、
									<br
									/>日本ではハンググライダーの距離飛行記録（クロスカントリーフライトレコード）は長い間、172.6Km（1988年富原淳氏）という大記録が存在し、多くの人々がそれを越えるべく挑戦を続けていました。
									<br
									/>私もいつかその更新をと夢見て飛んでいた一人でした。が結局、主に経済的な理由によりスポーツを継続していくことが困難となり、夢はかないませんでした。
									<br />『ov172xcr』には、『越えろ！172Kmのクロスカントリーフライト記録を。』という意味が込められています。
									<br />因みに、仲間の一人はその後も飛び続け、ハンググライダー（クラス5）の世界チャンピオンになりました。
								</p>
							</div>
						</Prose>
					</div>
					<Image src={Ava} alt='クロスカントリーフライトのイメージ' width={500} class='rounded-3xl rotate-3 mx-4 md:mx-0' />
				</div>
				<div>
					<p>
						<a href='https://www.aero.or.jp/news/13685/' target='_blank' rel='noopener noreferrer'
							>ハンググライダー（クラス5）世界選手権で日本人選手が初優勝！</a
						>
					</p>
				</div>
			</article>
		</main>
	</div>
</BaseLayout>
