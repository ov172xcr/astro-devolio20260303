---
// ============================================
// blog/index.astro - ブログ記事一覧ページ
// ============================================
// microCMS から全てのブログ記事を取得し、
// Goodpatch Blog を参考にした2カラムグリッドで表示します。
//
// 【このページの仕組み】
// 1. フロントマター（---）内で microCMS API から記事一覧を取得
// 2. 取得したデータを BlogCard コンポーネントに渡してループ表示
//
// 【Goodpatch Blog 風のレイアウト】
// - 2カラムのグリッドレイアウト（モバイルは1カラム）
// - 白いカードに角丸とシャドウ
// - タグバッジとカテゴリ表示
// ============================================

import Layout from "../../layouts/Layout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getBlogs } from "../../lib/microcms";

// ============================================
// microCMS から全記事を取得
// ============================================
// orders: '-date' で新しい順にソート
// limit はデフォルト（10件）。必要に応じて増やせます。
let blogs: any[] = [];
let totalCount = 0;
try {
    const response = await getBlogs({ orders: "-date", limit: 100 });
    blogs = response.contents;
    totalCount = response.totalCount;
} catch (error) {
    console.error("ブログ記事の取得に失敗しました:", error);
}

// 全タグを抽出（フィルタリング用）
// Set を使って重複を排除
// flat() で二次元配列を一次元に展開
const allTags = [...new Set(blogs.flatMap((blog) => blog.tag || []))];
---

<Layout
    title="ブログ一覧"
    description="microCMS で管理されたブログ記事の一覧です"
>
    {
        /* ============================================
      ページヘッダー
      ============================================
      ブログ一覧ページの上部にタイトルと説明を表示 */
    }
    <section class="pt-12 pb-8 px-4">
        <div class="max-w-6xl mx-auto text-center">
            <p
                class="text-primary-dark font-medium text-sm tracking-widest uppercase mb-2"
            >
                Blog
            </p>
            <h1 class="text-4xl md:text-5xl font-bold text-text-main mb-4">
                ブログ記事
            </h1>
            <p class="text-text-sub text-lg">全 {totalCount} 件の記事</p>
            <div class="w-16 h-1 bg-accent mx-auto mt-4 rounded-full"></div>
        </div>
    </section>

    {
        /* ============================================
      タグフィルター（表示用）
      ============================================
      Goodpatch Blog のようなタグナビゲーション */
    }
    {
        allTags.length > 0 && (
            <section class="px-4 pb-8">
                <div class="max-w-6xl mx-auto">
                    <div class="flex flex-wrap justify-center gap-3">
                        {allTags.map((tag) => (
                            <span class="text-sm font-medium px-4 py-1.5 rounded-full bg-white/60 text-text-main hover:bg-white hover:shadow-md transition-all cursor-default">
                                #{tag}
                            </span>
                        ))}
                    </div>
                </div>
            </section>
        )
    }

    {
        /* ============================================
      記事一覧グリッド
      ============================================
      Goodpatch Blog 風の2カラムグリッドレイアウト

      grid-cols-1: モバイルでは1カラム
      md:grid-cols-2: タブレット以上で2カラム
      gap-8: カード間のスペース
      ============================================ */
    }
    <section class="px-4 pb-20">
        <div class="max-w-6xl mx-auto">
            {
                blogs.length > 0 ? (
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        {/* 記事の数だけ BlogCard コンポーネントを表示 */}
                        {/* .map() で配列の各要素を BlogCard に変換 */}
                        {blogs.map((blog) => (
                            <BlogCard
                                title={blog.title}
                                slug={blog.slug}
                                description={blog.description}
                                date={blog.date}
                                tag={blog.tag || []}
                                coverimage={blog.coverimage}
                            />
                        ))}
                    </div>
                ) : (
                    /* 記事がない場合 */
                    <div class="text-center py-20 bg-white/40 rounded-2xl">
                        <p class="text-2xl mb-4">📝</p>
                        <p class="text-xl text-text-sub">
                            まだ記事がありません
                        </p>
                        <p class="text-sm text-text-sub mt-2">
                            microCMS
                            のダッシュボードからブログ記事を作成してください
                        </p>
                    </div>
                )
            }
        </div>
    </section>
</Layout>
