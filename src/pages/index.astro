---
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Ava from '@src/assets/img/xcflight.jpg';
import Prose from '../components/Prose.astro';
import { projects } from './projects/projects';
import ProjectList from '../components/ProjectList.astro';
import PostItem from '../components/PostItem.astro';

type BlogPost = CollectionEntry<'blog'>;

const top6Projects = projects.slice(0, 6);
const posts = (await getCollection('blog'))
	.sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<BaseLayout title={SITE_TITLE + ' - ' + SITE_TAGLINE} description={SITE_DESCRIPTION}>
	<div class='container'>
		<div class='w-full md:flex md:items-center gap-16 mb-10'>
			<div class='text-pretty leading-9'>
				<h1 class='text-4xl font-bold mb-4'>ov172xcrです。<br />こんにちは！</h1>
				<Prose>
					<div class='text-lg'>
						<p>
							私は日本在住のWebデザイナーです。<br
							/>若い頃はスカイスポーツのハンググライダーに夢中になり、仲間と競い合って特に遠くまで飛ぶことに関心がありました。いつかクロスカントリー（XC）フライトの日本記録（当時172Km）を更新したいと思っていました。
						</p>
						<p>
							フロントエンド開発も学習中です。Astroとtailwind、microCMSの組み合わせに将来性感じています。GitHubを含め、解らない事ばかりですが、地道に取り組んでいます。
						</p>
					</div>
				</Prose>
			</div>
			<Image src={Ava} alt='クロスカントリーフライトのイメージ' width={500} loading='eager' class='rounded-3xl rotate-3 mx-4 md:mx-0' />
		</div>
	<section class="py-20 px-4">
		<div class="max-w-4xl mx-auto">
			<div
				class="bg-white/50 backdrop-blur-sm rounded-3xl p-10 md:p-14 shadow-lg"
			>
				<div class="text-center mb-8">
					<p
						class="text-primary-dark font-medium text-sm tracking-widest uppercase mb-2"
					>
						About This Blog
					</p>
					<h2 class="text-3xl font-bold text-text-main">
						このブログについて
					</h2>
					<div class="w-16 h-1 bg-accent mx-auto mt-4 rounded-full">
					</div>
				</div>
				<p
					class="text-text-main text-lg leading-relaxed text-center mb-8"
				>
					このサイトは、ヘッドレスCMS「<strong>microCMS</strong>」と
					モダンフレームワーク「<strong>Astro</strong
					>」を使って構築された 実習用のブログサイトです。<br />
					Tailwind CSS によるスタイリングと、 JavaScript によるAPI連携の実践的な学びを提供します。
				</p>

				{/* 技術アイコン */}
				<div class="flex justify-center gap-6 flex-wrap">
					<div
						class="flex items-center gap-2 bg-primary/20 px-4 py-2 rounded-full text-sm font-medium text-text-main"
					>
						🚀 Astro
					</div>
					<div
						class="flex items-center gap-2 bg-primary/20 px-4 py-2 rounded-full text-sm font-medium text-text-main"
					>
						📦 microCMS
					</div>
					<div
						class="flex items-center gap-2 bg-primary/20 px-4 py-2 rounded-full text-sm font-medium text-text-main"
					>
						🎨 Tailwind CSS
					</div>
				</div>
			</div>
		</div>
	</section>
	</div>
</BaseLayout>
